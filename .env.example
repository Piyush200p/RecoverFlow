# RecoverFlow AI — Environment Variables (Development)
# =====================================================
# Copy this to .env and fill in your actual keys.

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://recoverflow:recoverflow@db:5432/recoverflow

# ── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Shopify App Credentials ─────────────────
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# ── Google Gemini ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Meta WhatsApp Cloud API ──────────────────
WHATSAPP_DEFAULT_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_DEFAULT_PHONE_NUMBER_ID=your_phone_number_id_here

# ── Application ─────────────────────────────
DEBUG=true
